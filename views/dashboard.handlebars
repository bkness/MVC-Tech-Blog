<div id="create-post">
  <a href="/post">  <button id="create-post-button">Post a Blog</button></a>
</div>

{{#if blogs.length}}
{{#each blogs}}
  <div class="top-container" id="blog-post" data-blog-id="{{id}}">
        <div id="blog-title">
            <h2>{{title}} </h2>
            <p><i>Published by {{user.name}} on {{format_date dateCreated}}</i></p>
        </div>
        <div class="blog-body" id="content-body">
            <p>{{contentPost}}</p>
        </div>
        <div id="blog-comment">
            <a href="/blog/{{id}}">Comment</a>
             <button id="delete-blog" type="submit" class="btn">Delete</button>
        </div>
    </div>
{{/each}}
{{else}}
  <p style="text-align:center; margin-top: 30px; color: azure; background: rgba(0,0,0,0.5); padding: 12px; border-radius: 6px; width: fit-content; margin-left: auto; margin-right: auto;">No posts yet — hit the button above to write your first one.</p>
{{/if}}

<script src="/js/delete-blog.js"></script>